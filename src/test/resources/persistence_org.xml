<?xml version="1.0" encoding="UTF-8"?>

<persistence version="2.0" xmlns="http://java.sun.com/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/persistence     http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd">
    <persistence-unit name="jpa-pu">
        <description>ECM Persistence Unit</description>
        <provider>org.javalabs.jpa.LitePersistenceProvider</provider>
        
        <class>org.javalabs.jpa.model.Employee</class>
        
        <shared-cache-mode>NONE</shared-cache-mode>
        <properties>
            <!--property name="jpa-lite.dialect" value="h2"/-->
            <property name="jpa-lite.entity.package" value="org.javalabs.common.model"/>
            
            <property name="javax.persistence.jdbc.url" value="jdbc:h2:mem:jpadb;DB_CLOSE_DELAY=-1"/>
            <property name="javax.persistence.jdbc.user" value="jpalite"/>
            <property name="javax.persistence.jdbc.password" value="jpalite"/>
            
            <!--
            Defines which scripts the persistence provider shall create.
            A script target needs to be defined for each script to be created.
            -->
            <property name="javax.persistence.schema-generation.scripts.action" value="drop-and-create"/>
            
            <!-- Defines the target location of the create script generated by the persistence provider -->
            <property name="javax.persistence.schema-generation.scripts.create-target" value="table.sql"/>
            
            <!-- Defines if the persistence provider shall also create the required database objects like tables and indexes -->
            <property name="javax.persistence.schema-generation.create-database-schemas" value="true"/>
            
            <!-- property name="jpa-lite.data.source" value="org.javalabs.util.ECMPoolDataSource"/-->
            <property name="jpa-lite.logging.level" value="TRACE"/>
            <property name="jpa-lite.dao.package" value="org.javalabs.jpa.model"/>
        </properties>
    </persistence-unit>
</persistence>
